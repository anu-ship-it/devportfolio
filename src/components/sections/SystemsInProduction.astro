---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
---

<Section>

  <div class="mx-auto max-w-[1320px]">

    <!-- Header -->

    <div class="max-w-3xl">

      <p
        class="text-xs font-semibold uppercase tracking-[0.32em] text-emerald-400"
      >
        PRODUCT ECOSYSTEM
      </p>

      <h2
        class="mt-6 text-5xl font-black leading-tight tracking-[-0.04em]"
      >
        Products solving
        real-world problems.
      </h2>

      <p
        class="mt-8 max-w-2xl text-lg leading-8 text-zinc-400"
      >
        Every product represents a different intelligence domain—from AI cost
        intelligence and developer productivity to intelligent automation and
        research systems.
      </p>

    </div>

    <!-- Featured Product -->

    <article
      class="mt-16 rounded-[32px] border border-white/10 bg-gradient-to-b from-white/[0.05] to-white/[0.02] p-10 transition-all duration-300 hover:border-emerald-400/30 hover:shadow-[0_30px_80px_rgba(16,185,129,.08)]"
    >

      <!-- Top -->

      <div
        class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between"
      >

        <div class="max-w-2xl">

          <span
            class="text-xs font-semibold uppercase tracking-[0.28em] text-emerald-400"
          >
            FEATURED PRODUCT
          </span>

          <h3
            class="mt-5 text-5xl font-bold tracking-tight"
          >
            TokenPulse
          </h3>

          <p
            class="mt-5 text-lg leading-8 text-zinc-400"
          >
            Real-time token analytics, usage tracking and AI cost intelligence
            for ChatGPT, Claude and Gemini. Built for developers who want
            complete visibility into AI usage and spending.
          </p>

        </div>

        <div
          class="inline-flex h-fit items-center gap-2 rounded-full border border-emerald-400/30 bg-emerald-400/10 px-5 py-2.5"
        >

          <div
            class="h-2.5 w-2.5 rounded-full bg-emerald-400"
          ></div>

          <span
            class="text-sm font-semibold text-emerald-400"
          >
            Live
          </span>

        </div>

      </div>

      <!-- Metrics -->

      <div
        class="my-10 h-px bg-white/10"
      ></div>

      <div
        class="grid gap-8 md:grid-cols-3"
      >

        <div>

          <p
            class="text-xs uppercase tracking-[0.24em] text-zinc-500"
          >
            USERS
          </p>

          <h4
            class="mt-3 text-3xl font-bold"
          >
            100+
          </h4>

        </div>

        <div>

          <p
            class="text-xs uppercase tracking-[0.24em] text-zinc-500"
          >
            PLATFORM
          </p>

          <h4
            class="mt-3 text-xl font-semibold"
          >
            Chrome + Edge
          </h4>

        </div>

        <div>

          <p
            class="text-xs uppercase tracking-[0.24em] text-zinc-500"
          >
            STATUS
          </p>

          <h4
            class="mt-3 text-xl font-semibold text-emerald-400"
          >
            Shipping Weekly
          </h4>

        </div>

      </div>

      <div
        class="my-10 h-px bg-white/10"
      ></div>

      <!-- Bottom -->

      <div
        class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between"
      >

        <div>

          <p
            class="text-xs uppercase tracking-[0.24em] text-zinc-500"
          >
            BUILT FOR
          </p>

          <p
            class="mt-3 text-lg leading-8 text-zinc-300"
          >
            Developers • AI Teams • Power Users
          </p>

        </div>

        <Button href="#">

          View Product

        </Button>

      </div>

    </article>

        <!-- Products Grid -->

    <div
      class="mt-12 grid gap-8 lg:grid-cols-3"
    >

      <!-- Velra -->

      <article
        class="group rounded-[28px] border border-white/10 bg-[var(--surface)] p-9 transition-all duration-300 hover:-translate-y-2 hover:border-amber-400/30 hover:bg-white/[0.03]"
      >

        <div
          class="flex items-center justify-between"
        >

          <span
            class="text-xs font-medium uppercase tracking-[0.22em] text-zinc-500"
          >
            AI Workspace
          </span>

          <div
            class="h-2.5 w-2.5 rounded-full bg-amber-400 shadow-[0_0_16px_rgba(251,191,36,.5)]"
          ></div>

        </div>

        <h3
          class="mt-5 text-3xl font-bold tracking-tight"
        >
          Velra
        </h3>

        <p
          class="mt-5 leading-8 text-zinc-400"
        >
          AI workspace focused on intelligent productivity, agent workflows and
          modern knowledge management.
        </p>

        <div
          class="my-8 h-px bg-white/10"
        ></div>

        <div
          class="flex items-center justify-between"
        >

          <span
            class="text-sm text-zinc-500"
          >
            Private Preview
          </span>

          <span
            class="text-sm font-medium text-white transition-transform duration-300 group-hover:translate-x-1"
          >
            Learn More →
          </span>

        </div>

      </article>

      <!-- AI Dev Weekly -->

      <article
        class="group rounded-[28px] border border-white/10 bg-[var(--surface)] p-9 transition-all duration-300 hover:-translate-y-2 hover:border-amber-400/30 hover:bg-white/[0.03]"
      >

        <div
          class="flex items-center justify-between"
        >

          <span
            class="text-xs font-medium uppercase tracking-[0.22em] text-zinc-500"
          >
            Newsletter
          </span>

          <div
            class="h-2.5 w-2.5 rounded-full bg-amber-400 shadow-[0_0_16px_rgba(251,191,36,.5)]"
          ></div>

        </div>

        <h3
          class="mt-5 text-3xl font-bold tracking-tight"
        >
          AI Dev Weekly
        </h3>

        <p
          class="mt-5 leading-8 text-zinc-400"
        >
          Weekly insights covering AI engineering, developer tools, LLMs and
          the latest advancements in AI.
        </p>

        <div
          class="my-8 h-px bg-white/10"
        ></div>

        <div
          class="flex items-center justify-between"
        >

          <span
            class="text-sm text-zinc-500"
          >
            Weekly Publication
          </span>

          <span
            class="text-sm font-medium text-white transition-transform duration-300 group-hover:translate-x-1"
          >
            Learn More →
          </span>

        </div>

      </article>

      <!-- AlphaPulse -->

      <article
        class="group rounded-[28px] border border-white/10 bg-[var(--surface)] p-9 transition-all duration-300 hover:-translate-y-2 hover:border-sky-400/30 hover:bg-white/[0.03]"
      >

        <div
          class="flex items-center justify-between"
        >

          <span
            class="text-xs font-medium uppercase tracking-[0.22em] text-zinc-500"
          >
            Research Platform
          </span>

          <div
            class="h-2.5 w-2.5 rounded-full bg-sky-400 shadow-[0_0_16px_rgba(56,189,248,.45)]"
          ></div>

        </div>

        <h3
          class="mt-5 text-3xl font-bold tracking-tight"
        >
          AlphaPulse
        </h3>

        <p
          class="mt-5 leading-8 text-zinc-400"
        >
          Experimental AI platform focused on intelligent agents, autonomous
          systems and next-generation AI products.
        </p>

        <div
          class="my-8 h-px bg-white/10"
        ></div>

        <div
          class="flex items-center justify-between"
        >

          <span
            class="text-sm text-zinc-500"
          >
            Research
          </span>

          <span
            class="text-sm font-medium text-white transition-transform duration-300 group-hover:translate-x-1"
          >
            Learn More →
          </span>

        </div>

      </article>

    </div>

  </div>

</Section>
