---
import Section from "../ui/Section.astro";
import Heading from "../ui/Heading.astro";
import ProductCard from "../ui/ProductCard.astro";
import { products } from "../../data/products";

const featured = products.find(product => product.featured);

const others = products.filter(product => !product.featured);
---

<Section>

    <Heading
        eyebrow="FLAGSHIP PRODUCTS"
        title="Products with real impact."
        description="Every product begins with a real problem, is validated through feedback and continuously evolves with real users."
    />

    {
        featured && (

            <div class="mt-16">

                <ProductCard
                    category={featured.category}
                    title={featured.name}
                    tagline={featured.tagline}
                    description={featured.description}
                    status={featured.status}
                    href={featured.href}
                    featured
                />

            </div>

        )
    }

    <div class="mt-10 grid gap-8 lg:grid-cols-3">

        {
            others.map(product => (

                <ProductCard
                    category={product.category}
                    title={product.name}
                    tagline={product.tagline}
                    description={product.description}
                    status={product.status}
                    href={product.href}
                />

            ))
        }

    </div>

</Section>
