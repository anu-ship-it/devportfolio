---
import Container from "../ui/Container.astro";
import currentMission from "../../data/current";
---

<section class="py-32">

  <Container>

    <div class="max-w-3xl">

      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-[var(--primary)]">
        CURRENT MISSION
      </p>

      <h2 class="mt-5 text-5xl font-bold tracking-tight">
        Building today for tomorrow.
      </h2>

      <p class="mt-6 text-lg leading-8 text-[var(--foreground-secondary)]">
        Every product is continuously evolving. Here's where my engineering
        focus is currently invested.
      </p>

    </div>

    <div class="mt-20 space-y-6">

      {
        currentMission.map((item) => (

          <div
            class="group flex flex-col gap-6 rounded-3xl border border-[var(--border)] p-8 transition-all duration-300 hover:border-[var(--primary)] lg:flex-row lg:items-center lg:justify-between"
          >

            <div class="flex items-start gap-5">

              <div
                class="mt-2 h-3 w-3 rounded-full bg-emerald-400"
              ></div>

              <div>

                <h3 class="text-2xl font-semibold">
                  {item.title}
                </h3>

                <p class="mt-3 max-w-2xl leading-8 text-[var(--foreground-secondary)]">
                  {item.description}
                </p>

              </div>

            </div>

            <span
              class="rounded-full border border-[var(--border)] px-4 py-2 text-sm font-medium"
            >
              {item.status}
            </span>

          </div>

        ))
      }

    </div>

  </Container>

</section>
