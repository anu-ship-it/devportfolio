---
import Section from "../ui/Section.astro";
import Heading from "../ui/Heading.astro";
import currentMission from "../../data/current";
---

<Section>

    <div class="grid gap-20 lg:grid-cols-[420px_1fr]">

        <Heading
            eyebrow="CURRENT MISSION"
            title="Focused on shipping products."
            description="Building, validating and improving AI products every week."
        />

        <div class="space-y-8">

            {
                currentMission.map(item => (

                    <div
                        class="flex items-start gap-6 rounded-2xl border border-[var(--border)] p-6 transition hover:border-[var(--primary)]"
                    >

                        <div
                            class="mt-2 h-3 w-3 rounded-full bg-green-400"
                        ></div>

                        <div class="flex-1">

                            <div
                                class="flex items-center justify-between"
                            >

                                <h3
                                    class="text-xl font-semibold"
                                >

                                    {item.title}

                                </h3>

                                <span
                                    class="rounded-full bg-[var(--surface-secondary)] px-3 py-1 text-xs"
                                >

                                    {item.status}

                                </span>

                            </div>

                            <p
                                class="mt-3 leading-7 text-[var(--foreground-secondary)]"
                            >

                                {item.description}

                            </p>

                        </div>

                    </div>

                ))
            }

        </div>

    </div>

</Section>
