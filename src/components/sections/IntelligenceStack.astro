---
import Section from "../ui/Section.astro";
import Heading from "../ui/Heading.astro";

const stack = [
  {
    title: "Developer Intelligence",
    product: "TokenPulse"
  },
  {
    title: "Knowledge Intelligence",
    product: "AI Dev Weekly"
  },
  {
    title: "Financial Intelligence",
    product: "AlphaPulse"
  },
  {
    title: "Productivity Intelligence",
    product: "Velra"
  }
];
---

<Section>

  <Heading
    eyebrow="THE INTELLIGENCE STACK"
    title="Four domains. One engineering philosophy."
    description="Every product transforms complex data into decisions."
  />

  <div class="mt-16 grid gap-6 lg:grid-cols-2">

    {
      stack.map(item => (

        <div
          class="rounded-[28px] border border-[var(--border)] p-8 transition-all duration-300 hover:border-[var(--primary)]"
        >

          <p
            class="text-xs uppercase tracking-[0.25em] text-[var(--primary)]"
          >
            {item.product}
          </p>

          <h3
            class="mt-4 text-2xl font-semibold"
          >
            {item.title}
          </h3>

        </div>

      ))
    }

  </div>

</Section>