---
import Section from "../ui/Section.astro";
import Heading from "../ui/Heading.astro";

const stack = [
  {
    title: "Developer Intelligence",
    product: "TokenPulse",
    icon: "01"
  },
  {
    title: "Knowledge Intelligence",
    product: "AI Dev Weekly",
    icon: "02"
  },
  {
    title: "Financial Intelligence",
    product: "AlphaPulse",
    icon: "03"
  },
  {
    title: "Productivity Intelligence",
    product: "Velra",
    icon: "04"
  }
];
---

<Section>

    <Heading
        eyebrow="THE INTELLIGENCE STACK"
        title="Four domains. One engineering philosophy."
        description="Building AI systems across developer tools, financial intelligence, knowledge discovery and productivity."
    />

    <div class="mt-20 divide-y divide-[var(--border)]">

        {
            stack.map(item => (

                <div
                    class="group grid gap-8 py-10 transition-all duration-300 lg:grid-cols-[120px_1fr_auto] lg:items-center"
                >

                    <span
                        class="text-4xl font-bold text-white/10 transition-all group-hover:text-[var(--primary)]"
                    >
                        {item.icon}
                    </span>

                    <div>

                        <h3 class="text-2xl font-semibold">

                            {item.title}

                        </h3>

                        <p
                            class="mt-2 text-[var(--foreground-secondary)]"
                        >

                            {item.product}

                        </p>

                    </div>

                    <span
                        class="text-sm opacity-0 transition-all duration-300 group-hover:translate-x-2 group-hover:opacity-100"
                    >

                        →

                    </span>

                </div>

            ))
        }

    </div>

</Section>
