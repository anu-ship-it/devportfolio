---
import Container from "../ui/Container.astro";
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";

const products = [
  {
    name: "TokenPulse",
    description:
      "Chrome extension for tracking AI token usage and real-time costs.",
    status: "Live",
  },
  {
    name: "Velra",
    description:
      "AI platform focused on productivity and intelligent workflows.",
    status: "Building",
  },
  {
    name: "Talk2Hire",
    description:
      "Video interview platform with scheduling and candidate management.",
    status: "Completed",
  },
];
---

<section class="py-24">

  <Container>

    <div class="mb-16">

      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.25em] text-[var(--primary)]">
        PRODUCTS
      </p>

      <h2 class="text-5xl font-bold">
        Products I've shipped.
      </h2>

      <p class="mt-5 max-w-2xl text-lg text-[var(--foreground-secondary)]">
        I enjoy building products that solve real problems rather than
        creating projects that only exist inside a portfolio.
      </p>

    </div>

    <div class="grid gap-8 lg:grid-cols-3">

      {
        products.map((product) => (

          <Card class="flex h-full flex-col justify-between">

            <div>

              <span
                class="rounded-full border border-[var(--border)] px-3 py-1 text-xs"
              >
                {product.status}
              </span>

              <h3 class="mt-6 text-2xl font-semibold">
                {product.name}
              </h3>

              <p class="mt-4 text-[var(--foreground-secondary)]">
                {product.description}
              </p>

            </div>

            <div class="mt-8">

              <Button
                href="/products"
                variant="secondary"
              >
                Learn More
              </Button>

            </div>

          </Card>

        ))
      }

    </div>

  </Container>

</section>
