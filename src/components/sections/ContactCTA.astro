---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
---

<section class="py-32">

  <Container>

    <div
      class="rounded-[40px] border border-[var(--border)] bg-[var(--surface)] px-10 py-20 text-center"
    >

      <p
        class="text-sm font-semibold uppercase tracking-[0.25em] text-[var(--primary)]"
      >
        LET'S BUILD
      </p>

      <h2
        class="mx-auto mt-6 max-w-4xl text-5xl font-bold tracking-tight"
      >
        I'm interested in building intelligent systems that help people make better decisions.
      </h2>

      <p
        class="mx-auto mt-8 max-w-2xl text-lg leading-8 text-[var(--foreground-secondary)]"
      >
        If you're building products powered by AI, automation or large-scale data,
        I'd love to hear about it.
      </p>

      <div class="mt-12 flex justify-center gap-4 flex-wrap">

        <Button href="mailto:anup17508@email.com">

          Get In Touch

        </Button>

        <Button
          href="https://github.com/anu-ship-it"
          variant="secondary"
        >

          GitHub

        </Button>

      </div>

    </div>

  </Container>

</section>
