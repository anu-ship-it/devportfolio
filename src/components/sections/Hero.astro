---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
---

<section class="relative overflow-hidden py-24 md:py-32">

  <Container>

    <div class="max-w-5xl">

      <span
        class="inline-flex items-center rounded-full border border-[var(--border)] px-4 py-2 text-sm font-medium text-[var(--primary)]"
      >
        AI Systems Engineer
      </span>

      <h1 class="mt-8 max-w-5xl text-5xl font-bold leading-[1.05] tracking-tight md:text-7xl">

        Building intelligent systems that transform complex data into actionable decisions.

      </h1>

      <p class="mt-8 max-w-3xl text-xl leading-9 text-[var(--foreground-secondary)]">

        I design and build AI-powered products that collect information,
        analyze signals, rank opportunities and help people make better
        decisions. My work spans developer tools, financial intelligence,
        knowledge discovery and AI productivity systems.

      </p>

      <div class="mt-12 flex flex-wrap gap-4">

        <Button href="/systems">

          Explore Systems

        </Button>

        <Button
          href="/resume.pdf"
          variant="secondary"
        >

          Download Resume

        </Button>

      </div>

    </div>

  </Container>

</section>