---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="pt-16 lg:pt-24">

    <div class="max-w-5xl">

        <span
            class="inline-flex items-center rounded-full border border-[var(--border)] px-4 py-2 text-sm font-medium text-[var(--primary)]"
        >
            AI Systems Engineer
        </span>

        <h1
            class="mt-8 max-w-5xl text-5xl font-bold leading-[1.05] tracking-tight md:text-6xl lg:text-7xl"
        >
            Building intelligent systems that transform complex data into actionable decisions.
        </h1>

        <p
            class="mt-8 max-w-2xl text-lg leading-8 text-[var(--foreground-secondary)]"
        >
            I build AI-powered products that collect information, extract meaningful
            signals and help developers, businesses and investors make better
            decisions through intelligent software.
        </p>

        <div class="mt-12 flex flex-wrap gap-4">

            <Button href="/systems">
                Explore Systems
            </Button>

            <Button
                href="/resume.pdf"
                variant="secondary"
            >
                Download Resume
            </Button>

        </div>

    </div>

</Section>
