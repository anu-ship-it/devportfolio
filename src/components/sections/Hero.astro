---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="min-h-[90vh] flex items-center">

  <div class="grid items-center gap-16 lg:grid-cols-[1.05fr_0.95fr]">

    <!-- LEFT -->

    <div class="max-w-3xl">

      <div
        class="inline-flex items-center gap-3 rounded-full border border-[var(--border)] bg-[var(--surface)] px-4 py-2"
      >
        <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

        <span class="text-sm font-medium">
          AI Systems Engineer
        </span>
      </div>

      <h1
        class="mt-8 text-4xl font-bold leading-[1.02] tracking-[-0.05em] md:text-5xl xl:text-6xl"
      >
        Building

        <span class="text-white">
          intelligent systems
        </span>

        that transform complex data into

        <span class="text-zinc-400">
          actionable decisions.
        </span>
      </h1>

      <p
        class="mt-8 max-w-lg text-lg leading-8 text-[var(--foreground-secondary)]"
      >
        AI-powered products across developer tools,
        financial intelligence and intelligent automation.
      </p>

      <!-- TRUST -->

      <div class="mt-10 space-y-3">

        <div class="flex items-center gap-3">

          <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

          <span class="text-sm text-zinc-300">

            100+ developers actively using TokenPulse

          </span>

        </div>

        <div class="flex items-center gap-3">

          <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

          <span class="text-sm text-zinc-300">

            4 AI products under active development

          </span>

        </div>

        <div class="flex items-center gap-3">

          <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

          <span class="text-sm text-zinc-300">

            Shipping improvements every week

          </span>

        </div>

      </div>

      <div class="mt-12 flex flex-wrap gap-4">

        <Button href="/systems">

          View Products

        </Button>

        <Button
          href="/resume.pdf"
          variant="secondary"
        >

          Resume

        </Button>

      </div>

    </div>

    <!-- RIGHT -->

    <div class="flex justify-end">

      <div
        class="w-full max-w-md rounded-[32px] border border-[var(--border)] bg-[var(--surface)] p-8"
      >

        <div class="flex items-center justify-between">

          <span
            class="text-xs uppercase tracking-[0.30em] text-zinc-500"
          >
            LIVE
          </span>

          <div class="flex items-center gap-2">

            <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

            <span class="text-xs">

              Active

            </span>

          </div>

        </div>

        <h2
          class="mt-8 text-4xl font-bold"
        >

          TokenPulse

        </h2>

        <p
          class="mt-4 leading-7 text-[var(--foreground-secondary)]"
        >

          Real-time AI token analytics and cost intelligence
          for modern LLM platforms.

        </p>

        <div
          class="mt-10 grid grid-cols-2 gap-8 border-y border-[var(--border)] py-8"
        >

          <div>

            <p class="text-sm text-zinc-500">

              Users

            </p>

            <h3 class="mt-2 text-3xl font-bold">

              100+

            </h3>

          </div>

          <div>

            <p class="text-sm text-zinc-500">

              Products

            </p>

            <h3 class="mt-2 text-3xl font-bold">

              4

            </h3>

          </div>

        </div>

        <div class="mt-8">

          <p class="text-sm text-zinc-500">

            CURRENTLY BUILDING

          </p>

          <div class="mt-5 space-y-3">

            <div class="flex items-center justify-between">

              <span>Velra</span>

              <span class="text-zinc-500">AI Workspace</span>

            </div>

            <div class="flex items-center justify-between">

              <span>AI Dev Weekly</span>

              <span class="text-zinc-500">Beta</span>

            </div>

            <div class="flex items-center justify-between">

              <span>AlphaPulse</span>

              <span class="text-zinc-500">Private</span>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</Section>
