---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="min-h-[88vh] flex items-center">

    <div class="grid gap-20 lg:grid-cols-[1.2fr_420px] lg:items-center">

        <!-- LEFT -->

        <div>

            <div
                class="inline-flex items-center gap-2 rounded-full border border-[var(--border)] bg-[var(--surface)] px-4 py-2"
            >

                <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

                <span class="text-sm">

                    AI Systems Engineer

                </span>

            </div>

            <h1
                class="mt-8 max-w-4xl text-5xl font-bold leading-[1.02] tracking-tight lg:text-7xl"
            >

                Building intelligent systems that transform complex data into actionable decisions.

            </h1>

            <p
                class="mt-8 max-w-xl text-lg leading-8 text-[var(--foreground-secondary)]"
            >

                AI-powered products across developer tools,
                financial intelligence and intelligent automation.

            </p>

            <div
                class="mt-12 flex flex-wrap gap-4"
            >

                <Button href="/systems">

                    Explore Systems

                </Button>

                <Button
                    href="/resume.pdf"
                    variant="secondary"
                >

                    Resume

                </Button>

            </div>

        </div>

        <!-- RIGHT -->

        <aside
            class="rounded-[32px] border border-[var(--border)] bg-[var(--surface)] p-8"
        >

            <p
                class="text-xs uppercase tracking-[0.3em] text-[var(--primary)]"
            >

                CURRENT SNAPSHOT

            </p>

            <div class="mt-8 space-y-8">

                <div>

                    <p class="text-sm text-[var(--foreground-secondary)]">

                        Flagship Product

                    </p>

                    <h3 class="mt-2 text-2xl font-semibold">

                        TokenPulse

                    </h3>

                </div>

                <div class="grid grid-cols-2 gap-6">

                    <div>

                        <p class="text-sm text-[var(--foreground-secondary)]">

                            Users

                        </p>

                        <h4 class="mt-2 text-3xl font-bold">

                            100+

                        </h4>

                    </div>

                    <div>

                        <p class="text-sm text-[var(--foreground-secondary)]">

                            Systems

                        </p>

                        <h4 class="mt-2 text-3xl font-bold">

                            4

                        </h4>

                    </div>

                </div>

                <div class="border-t border-[var(--border)] pt-6">

                    <p class="text-sm text-[var(--foreground-secondary)]">

                        Currently Building

                    </p>

                    <ul class="mt-4 space-y-3">

                        <li>• Velra</li>

                        <li>• AI Dev Weekly</li>

                        <li>• AlphaPulse</li>

                    </ul>

                </div>

            </div>

        </aside>

    </div>

</Section>
