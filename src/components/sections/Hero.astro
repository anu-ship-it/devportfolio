---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
---

<section
  class="relative overflow-hidden py-32 lg:py-40"
>

  <Container>

    <div
      class="max-w-5xl"
    >

      <span
        class="inline-flex rounded-full border border-[var(--border)] px-4 py-2 text-sm text-[var(--foreground-secondary)]"
      >
        Building products for developers.
      </span>

      <h1
        class="mt-8 max-w-5xl text-5xl font-bold leading-tight tracking-tight md:text-7xl"
      >
        Shipping AI products
        that developers
        actually use.
      </h1>

      <p
        class="mt-8 max-w-2xl text-xl leading-9 text-[var(--foreground-secondary)]"
      >
        I build AI-powered developer tools,
        Chrome extensions and scalable backend
        systems from idea to production.

        Currently building TokenPulse and Velra.
      </p>

      <div
        class="mt-12 flex flex-wrap gap-4"
      >

        <Button
          href="/products"
        >
          View Products
        </Button>

        <Button
          href="/resume.pdf"
          variant="secondary"
        >
          Download Resume
        </Button>

      </div>

    </div>

  </Container>

</section>
