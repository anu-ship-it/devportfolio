---
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="min-h-screen flex items-center pt-36">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="grid items-center gap-32 xl:grid-cols-[820px_500px]">
      <!-- LEFT -->

      <div class="max-w-[760px]">
        <div
          class="inline-flex items-center gap-3 rounded-full border border-[var(--border)] bg-[var(--surface)] px-5 py-2.5"
        >
          <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

          <span class="text-sm font-medium tracking-wide">
            AI Systems Engineer
          </span>
        </div>

        <h1
          class="mt-8 text-5xl font-black leading-[0.98] tracking-[-0.055em] xl:text-[5rem]"
        >
          Building intelligent systems

          <br />

          that transform complex

          <br />

          data into actionable decisions.
        </h1>

        <p
          class="mt-8 max-w-xl text-lg leading-8 text-[var(--foreground-secondary)]"
        >
          Building AI products across developer tools, financial intelligence,
          automation and modern software engineering.
        </p>

        <!-- Trust -->

        <div class="mt-10 space-y-4">
          <div class="flex items-center gap-3">
            <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

            <span>100+ Active Users</span>
          </div>

          <div class="flex items-center gap-3">
            <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

            <span>Shipping New Features Weekly</span>
          </div>

          <div class="flex items-center gap-3">
            <div class="h-2 w-2 rounded-full bg-emerald-400"></div>

            <span>Building 4 AI Systems</span>
          </div>
        </div>

        <!-- CTA -->

        <div class="mt-12 flex gap-5">
          <Button href="/projects"> Explore Products </Button>

          <Button href="/resume.pdf" variant="secondary"> Resume </Button>
        </div>
      </div>

      <!-- RIGHT -->

      <div class="justify-self-end self-start pt-2">
        <div
          class="w-[560px] rounded-[36px] border border-white/10 bg-gradient-to-b from-white/5 to-white/[0.02] p-12 shadow-[0_35px_80px_rgba(0,0,0,.45)] backdrop-blur-xl"
        >
          <div class="flex items-center justify-between py-2">
            <div class="flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full bg-emerald-400"></div>

              <span class="text-xs uppercase tracking-[0.28em]"> LIVE </span>
            </div>

            <span
              class="rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-2 text-xs text-emerald-300"
            >
              Active
            </span>
          </div>

          <h2 class="mt-8 text-4xl font-bold">TokenPulse</h2>

          <p class="mt-8 leading-8 text-lg text-[var(--foreground-secondary)]">
            AI token analytics, usage tracking and cost intelligence for
            ChatGPT, Claude and Gemini.
          </p>

          <div class="my-12 h-px bg-[var(--border)]"></div>

          <div class="space-y-8">
            <div class="flex items-center justify-between py-2">
              <span class="text-sm uppercase tracking-wide text-zinc-400">Version</span>

              <span>v2.1.0</span>
            </div>

            <div class="flex items-center justify-between py-2">
              <span class="text-sm uppercase tracking-wide text-zinc-400">Platform</span>

              <span>Chrome + Edge</span>
            </div>

            <div class="flex items-center justify-between py-2">
              <span class="text-sm uppercase tracking-wide text-zinc-400">AI Models</span>

              <span>GPT • Claude • Gemini</span>
            </div>

            <div class="flex items-center justify-between py-2">
              <span class="text-sm uppercase tracking-wide text-zinc-400">Status</span>

              <span class="text-emerald-400"> Live </span>
            </div>
          </div>

          <div class="my-10 h-px bg-[var(--border)]"></div>

          <h3 class="mt-12 text-sm uppercase tracking-[0.25em] text-zinc-400">
            Product Roadmap
          </h3>

          <div class="mt-12 space-y-6">
            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <div class="h-2.5 w-2.5 rounded-full bg-emerald-400"></div>

                <span>TokenPulse</span>
              </div>

              <span class="text-sm text-zinc-400"> Live </span>
            </div>

            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <div class="h-2.5 w-2.5 rounded-full bg-amber-400"></div>

                <span>Velra</span>
              </div>

              <span class="text-sm text-zinc-400"> Development </span>
            </div>

            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <div class="h-2.5 w-2.5 rounded-full bg-amber-400"></div>

                <span>AI Dev Weekly</span>
              </div>

              <span class="text-sm text-zinc-400"> Beta </span>
            </div>

            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <div class="h-2.5 w-2.5 rounded-full bg-sky-400"></div>

                <span>AlphaPulse</span>
              </div>

              <span class="text-sm text-zinc-400"> Research </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-24 flex justify-center">
    <div class="flex flex-col items-center gap-3 text-zinc-400">
      <span class="text-xs uppercase tracking-[0.35em]">
        Scroll to Explore
      </span>

      <div class="h-12 w-px bg-gradient-to-b from-zinc-500 to-transparent">
      </div>
    </div>
  </div>
</Section>
