---
import Container from "../ui/Container.astro";
import writing from "../../data/writing";
---

<section class="py-32">

  <Container>

    <div class="max-w-3xl">

      <p class="text-sm font-semibold uppercase tracking-[0.25em] text-[var(--primary)]">
        THINKING
      </p>

      <h2 class="mt-5 text-5xl font-bold tracking-tight">
        Writing about engineering,
        products and AI.
      </h2>

    </div>

    <div class="mt-16 space-y-6">

      {
        writing.map(article => (

          <a
            href={article.href}
            class="block rounded-3xl border border-[var(--border)] p-8 transition-all duration-300 hover:border-[var(--primary)] hover:-translate-y-1"
          >

            <h3 class="text-2xl font-semibold">

              {article.title}

            </h3>

            <p class="mt-4 max-w-3xl leading-8 text-[var(--foreground-secondary)]">

              {article.description}

            </p>

          </a>

        ))
      }

    </div>

  </Container>

</section>
