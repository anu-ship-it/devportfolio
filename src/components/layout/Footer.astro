---
import Container from "../ui/Container.astro";
import site from "../../data/site";
---

<footer class="border-t border-[var(--border)] py-10">

  <Container>

    <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">

      <div>

        <h3 class="text-xl font-semibold">

          {site.name}

        </h3>

        <p class="mt-3 text-[var(--foreground-secondary)]">

          Building intelligent systems that transform
          complex data into actionable decisions.

        </p>

      </div>

      <div class="flex gap-8 text-sm">

        {
          site.socials.map(link => (

            <a
              href={link.href}
              target="_blank"
              class="transition hover:text-[var(--primary)]"
            >

              {link.label}

            </a>

          ))
        }

      </div>

    </div>

  </Container>

</footer>
