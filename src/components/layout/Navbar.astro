---
import Container from "../ui/Container.astro";
import site from "../../data/site";

const currentPath = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-6 z-50">
  <Container>
    <nav
      class="mx-auto flex h-16 lg:h-[72px] max-w-[1280px] items-center justify-between rounded-full border border-white/10 bg-black/60 shadow-[0_12px_40px_rgba(0,0,0,.35)] px-8 backdrop-blur-xl"
    >
      <!-- Logo -->

      <a href="/" class="flex items-center gap-4">
        <div
          class="h-3 w-3 rounded-full bg-emerald-400 shadow-[0_0_18px_rgba(52,211,153,.7)]"
        >
        </div>

        <div>
          <h2 class="text-[30px] font-black uppercase tracking-[0.08em]">
            {site.shortName}
          </h2>

          <p class="mt-1 text-xs tracking-wide text-zinc-400">
            AI Systems Engineer
          </p>
        </div>
      </a>

      <!-- Navigation -->

      <div class="hidden items-center gap-12 lg:flex">
        {
          site.navigation.map((item) => (
            <a
              href={item.href}
              class:list={[
                "relative text-[16px] font-medium transition-colors duration-300 after:absolute after:-bottom-2 after:left-0 after:h-[2px] after:w-0 after:rounded-full after:bg-white after:transition-all",
                currentPath === item.href
                  ? "text-white after:w-full"
                  : "text-zinc-400 hover:text-white hover:after:w-full",
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- Resume -->

      <a
        href="/resume.pdf"
        class="group flex items-center gap-3 rounded-full border border-white/10 px-7 py-3.5 transition-all duration-300 hover:border-white/30 hover:bg-white/5"
      >
        <span class="font-medium"> Resume </span>

        <svg
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M7 17L17 7M17 7H8M17 7V16"></path>
        </svg>
      </a>
    </nav>
  </Container>
</header>
