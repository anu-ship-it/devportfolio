---
import Container from "../ui/Container.astro";
import site from "../../data/site";
---

<header
  class="sticky top-0 z-50 border-b border-[var(--border)] bg-black/70 backdrop-blur-xl"
>
  <Container>

    <div class="flex h-20 items-center justify-between">

      <a
        href="/"
        class="text-lg font-semibold tracking-tight"
      >
        {site.shortName}
      </a>

      <nav class="hidden items-center gap-8 lg:flex">

        {
          site.navigation.map((item) => (

            <a
              href={item.href}
              class="text-sm text-[var(--foreground-secondary)] transition hover:text-white"
            >
              {item.label}
            </a>

          ))
        }

      </nav>

      <a
        href="/resume.pdf"
        class="rounded-xl border border-[var(--border)] px-5 py-2.5 text-sm font-medium transition hover:bg-[var(--surface-secondary)]"
      >
        Resume
      </a>

    </div>

  </Container>
</header>
