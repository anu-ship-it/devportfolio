---
import Container from "../ui/Container.astro";
import site from "../../data/site";
---

<header
    class="sticky top-0 z-50 border-b border-[var(--border)] bg-black/70 backdrop-blur-xl"
>

    <Container>

        <div class="flex h-20 items-center justify-between">

            <a
                href="/"
                class="flex flex-col"
            >

                <span class="text-xl font-bold tracking-tight">

                    {site.shortName}

                </span>

                <span
                    class="text-xs text-[var(--foreground-secondary)]"
                >

                    AI Systems Engineer

                </span>

            </a>

            <nav
                class="hidden items-center gap-10 lg:flex"
            >

                {
                    site.navigation.map(item => (

                        <a
                            href={item.href}
                            class="text-sm font-medium text-[var(--foreground-secondary)] transition hover:text-white"
                        >

                            {item.label}

                        </a>

                    ))
                }

            </nav>

            <a
                href="/resume.pdf"
                class="rounded-xl border border-[var(--border)] px-5 py-3 text-sm font-medium transition hover:bg-[var(--surface-secondary)]"
            >

                Resume

            </a>

        </div>

    </Container>

</header>
