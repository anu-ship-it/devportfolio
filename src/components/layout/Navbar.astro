---
import Container from "../ui/Container.astro";
import site from "../../data/site";

const currentPath = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-5 z-50">

  <Container>

    <nav
      class="mx-auto flex h-20 max-w-[1380px] items-center justify-between rounded-full border border-white/10 bg-black/70 px-8 backdrop-blur-xl"
    >

      <!-- Logo -->

      <a
        href="/"
        class="flex items-center gap-4"
      >

        <div
          class="h-3 w-3 rounded-full bg-emerald-400 shadow-[0_0_18px_rgba(52,211,153,.7)]"
        ></div>

        <div>

          <h2
            class="text-2xl font-bold tracking-tight"
          >

            {site.shortName}

          </h2>

          <p
            class="text-sm text-[var(--foreground-secondary)]"
          >

            AI Systems Engineer

          </p>

        </div>

      </a>

      <!-- Navigation -->

      <div
        class="hidden items-center gap-10 lg:flex"
      >

        {
          site.navigation.map(item => (

            <a
              href={item.href}
              class:list={[
                "text-[15px] font-medium transition-all duration-300",
                currentPath === item.href
                  ? "text-white"
                  : "text-zinc-400 hover:text-white"
              ]}
            >

              {item.label}

            </a>

          ))
        }

      </div>

      <!-- Resume -->

      <a
        href="/resume.pdf"
        class="group flex items-center gap-3 rounded-full border border-white/10 px-6 py-3 transition-all duration-300 hover:border-emerald-400 hover:bg-white/5"
      >

        <span
          class="font-medium"
        >

          Resume

        </span>

        <svg
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >

          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M7 17L17 7M17 7H8M17 7V16"
          />

        </svg>

      </a>

    </nav>

  </Container>

</header>
