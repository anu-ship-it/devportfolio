---
interface Props {
  class?: string;
  hover?: boolean;
}

const {
  class: className = "",
  hover = true
} = Astro.props;
---

<div
  class:list={[
    "relative overflow-hidden",
    "rounded-[30px]",
    "border border-white/10",
    "bg-white/[0.02]",
    "backdrop-blur-sm",
    "transition-all duration-500",
    hover &&
      "hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.04]",
    "p-8 lg:p-10",
    className
  ]}
>

  <div
    class="absolute inset-0 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
    style="background:radial-gradient(circle at top right,rgba(255,255,255,.06),transparent 55%);"
  ></div>

  <div class="relative z-10">

    <slot />

  </div>

</div>
