---
interface Props {
  class?: string;
  hover?: boolean;
}

const {
  class: className = "",
  hover = true
} = Astro.props;
---

<div
  class:list={[
    "rounded-[28px]",
    "border border-[var(--border)]",
    "bg-[var(--surface)]",
    "p-8 lg:p-10",
    "transition-all duration-300",
    hover && "hover:-translate-y-1 hover:border-[var(--border-light)] hover:shadow-2xl",
    className
  ]}
>
    <slot />
</div>
