---
import Button from "./Button.astro";

interface Props {

    category:string;

    title:string;

    tagline:string;

    description:string;

    status:string;

    href:string;

    featured?:boolean;

}

const {

category,

title,

tagline,

description,

status,

href,

featured=false

}=Astro.props;
---

<article
class:list([

"group",

"overflow-hidden",

"rounded-[32px]",

"border",

"border-[var(--border)]",

"bg-[var(--surface)]",

"transition-all duration-500",

"hover:border-[var(--primary)]",

"hover:-translate-y-1",

featured
?"p-12"
:"p-8"

])}
>

<div class="flex items-center justify-between">

<span
class="text-xs uppercase tracking-[0.28em] text-[var(--primary)]"
>

{category}

</span>

<span
class="rounded-full border border-[var(--border)] px-3 py-1 text-xs"
>

{status}

</span>

</div>

<h3
class:list([

"mt-10 font-bold tracking-tight",

featured
?"text-5xl"
:"text-3xl"

])}
>

{title}

</h3>

<p
class="mt-5 text-xl font-medium"
>

{tagline}

</p>

<p
class="mt-6 max-w-2xl leading-8 text-[var(--foreground-secondary)]"
>

{description}

</p>

{
featured&&(

<div
class="mt-10 flex flex-wrap gap-3"
>

<div class="rounded-xl bg-[var(--surface-secondary)] px-5 py-4">

<p class="text-xs text-[var(--foreground-secondary)]">

Users

</p>

<p class="mt-2 text-xl font-semibold">

100+

</p>

</div>

<div class="rounded-xl bg-[var(--surface-secondary)] px-5 py-4">

<p class="text-xs text-[var(--foreground-secondary)]">

Platform

</p>

<p class="mt-2 text-xl font-semibold">

Chrome

</p>

</div>

<div class="rounded-xl bg-[var(--surface-secondary)] px-5 py-4">

<p class="text-xs text-[var(--foreground-secondary)]">

Status

</p>

<p class="mt-2 text-xl font-semibold">

Live

</p>

</div>

</div>

)
}

<div class="mt-10">

<Button
href={href}
variant={featured?"primary":"secondary"}
>

View Case Study

</Button>

</div>

</article>
