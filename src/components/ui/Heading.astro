---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = ""
} = Astro.props;

const center = align === "center";
---

<div
  class:list={[
    "max-w-3xl",
    center && "mx-auto text-center",
    className
  ]}
>

  {
    eyebrow && (
      <p
        class="mb-5 text-xs font-semibold uppercase tracking-[0.28em] text-[var(--primary)]"
      >
        {eyebrow}
      </p>
    )
  }

  <h2
    class="max-w-2xl text-4xl font-bold leading-[1.1] tracking-tight lg:text-5xl"
  >
    {title}
  </h2>

  {
    description && (
      <p
        class="mt-8 max-w-2xl text-lg leading-8 text-[var(--foreground-secondary)]"
      >
        {description}
      </p>
    )
  }

</div>
