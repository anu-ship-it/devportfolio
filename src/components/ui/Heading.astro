---
interface Props {

  eyebrow?: string;

  title: string;

  description?: string;

  align?: "left" | "center";

  class?: string;

}

const {

  eyebrow,

  title,

  description,

  align = "left",

  class: className = ""

} = Astro.props;

const centered = align === "center";
---

<div
  class:list={[
    centered && "mx-auto text-center",
    "max-w-3xl",
    className
  ]}
>

  {
    eyebrow && (

      <p
        class="text-xs font-semibold uppercase tracking-[0.30em] text-[var(--primary)]"
      >

        {eyebrow}

      </p>

    )
  }

  <h2
    class="mt-5 text-4xl font-bold leading-tight tracking-tight lg:text-5xl"
  >

    {title}

  </h2>

  {
    description && (

      <p
        class="mt-6 text-lg leading-8 text-[var(--foreground-secondary)]"
      >

        {description}

      </p>

    )
  }

</div>
