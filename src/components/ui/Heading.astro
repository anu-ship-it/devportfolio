---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = "",
} = Astro.props;

const alignment =
  align === "center"
    ? "mx-auto text-center"
    : "";
---

<div
  class:list={[
    "space-y-5",
    alignment,
    className,
  ]}
>
  {
    eyebrow && (
      <span
        class="inline-block text-sm font-semibold uppercase tracking-[0.25em] text-[var(--primary)]"
      >
        {eyebrow}
      </span>
    )
  }

  <h2
    class="max-w-5xl text-4xl font-bold tracking-tight text-[var(--foreground)] md:text-5xl lg:text-6xl"
  >
    {title}
  </h2>

  {
    description && (
      <p
        class="max-w-2xl text-lg leading-8 text-[var(--foreground-secondary)]"
      >
        {description}
      </p>
    )
  }
</div>
