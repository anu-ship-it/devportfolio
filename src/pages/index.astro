---
import BaseLayout from "../layouts/BaseLayout.astro";

import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";

import Container from "../components/ui/Container.astro";
import Section from "../components/ui/Section.astro";
import Button from "../components/ui/Button.astro";
---

<BaseLayout
  title="Anoop Kumar | Software Engineer"
>

<Navbar />

<main>

<Section>

<Container>

<div
class="max-w-5xl"
>

<p
class="mb-6 text-sm font-semibold uppercase tracking-[0.25em] text-[var(--primary)]"
>
SOFTWARE ENGINEER
</p>

<h1>

Building AI products
that developers
actually use.

</h1>

<p
class="mt-8 max-w-2xl"
>

I build developer tools, AI-powered software,
and scalable backend systems from idea to production.

Currently building TokenPulse and Velra.

</p>

<div
class="mt-10 flex flex-wrap gap-4"
>

<Button
href="/products"
>

View Products

</Button>

<Button
href="/resume.pdf"
variant="secondary"
>

Download Resume

</Button>

</div>

</div>

</Container>

</Section>

</main>

<Footer />

</BaseLayout>
